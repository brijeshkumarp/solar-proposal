{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },

    {
      "src": "/preview",
      "dest": "/public/preview.html"
    },
    {
      "src": "/list",
      "dest": "/public/list.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },

    {
      "handle": "filesystem"
    }
  ]
}