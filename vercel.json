{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/list",
      "dest": "/public/list.html"
    },
    {
      "src": "/preview/(.*)",
      "dest": "/public/preview.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}